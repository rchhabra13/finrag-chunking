# Local endpoints need no real keys — the OpenAI-compatible servers ignore them.
# Cloud endpoints (optional, for later comparison runs) read keys from these vars,
# referenced by `api_key_env` in config.yaml:

# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...          # used with base_url https://generativelanguage.googleapis.com/v1beta/openai/
# ANTHROPIC_API_KEY=sk-ant-...# used with base_url https://api.anthropic.com/v1/
